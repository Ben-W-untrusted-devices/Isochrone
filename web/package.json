{
  "name": "isochrone-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/app.js --bundle --minify --outfile=dist/app.js",
    "dev": "esbuild src/app.js --bundle --sourcemap --outfile=dist/app.js --watch",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.html\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.html\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "vitest": "^2.1.1"
  }
}
